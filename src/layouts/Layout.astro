---
const { title = "Accueil" } = Astro.props;
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} · Raphaël Djedai</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="icon" type="image/png" href="/mirage2000.png" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Inter:wght@300;400&display=swap">
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #07070a;
      --txt: #eeecea;
      --sub: #5a5a58;
      --dim: #18181e;
      --fr-b: #002395;
      --fr-w: #f0f0ea;
      --fr-r: #ED2939;
    }
    html { scroll-behavior: smooth; }
    body {
      background: var(--bg);
      color: var(--txt);
      font-family: 'Inter', sans-serif;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      -webkit-font-smoothing: antialiased;
    }
    a { color: inherit; text-decoration: none; }
    header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(7,7,10,0.95);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--dim);
    }
    nav {
      width: 100%;
      padding: 1.2rem 3rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .nav-logo {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic;
      font-size: 1.2rem;
      color: var(--txt);
    }
    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }
    .nav-links a {
      font-size: 0.78rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #c0c0ba;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--txt); }
    main {
      flex: 1;
      width: 100%;
      padding: 0 5rem;
    }
    footer { border-top: 1px solid var(--dim); margin-top: auto; }
    .footer-inner {
      max-width: 1100px;
      margin: 0 auto;
      padding: 1.4rem 5rem;
      display: flex;
      justify-content: space-between;
    }
    .footer-inner p {
      font-size: 0.7rem;
      letter-spacing: 0.07em;
      color: var(--sub);
    }
  </style>
</head>
<body>
  <header>
    <nav>
      <a href="/" class="nav-logo">Raphaël Djedai</a>
      <ul class="nav-links">
        <li><a href="/">Accueil</a></li>
        <li><a href="/parcours">Parcours &amp; CV</a></li>
        <li><a href="/projets">Projets</a></li>
        <li><a href="/articles">Articles</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </nav>
  </header>
  <main>
    <slot />
  </main>
  <footer>
    <div class="footer-inner">
      <p>© Raphaël Djedai</p>
      <p>France</p>
    </div>
  </footer>
</body>
</html>